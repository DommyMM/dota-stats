# --- API credentials ---
# OpenDota: optional $5/mo key removes the 60k/month cap. Leave blank for unauth.
OPENDOTA_API_KEY=

# Stratz: Default-tier JWT from https://stratz.com/api (log in with Steam).
# Remember: every Stratz request must also send User-Agent: STRATZ_API.
STRATZ_TOKEN=

# Steam Web API: free key from https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# --- Tracked accounts ---
# Comma-separated Dota 2 account_id (32-bit, NOT SteamID64). Me + friends, <= 10.
# Convert from SteamID64: account_id = steamid64 - 76561197960265728
TRACKED_ACCOUNT_IDS=

# --- Storage ---
DUCKDB_PATH=data/dota.duckdb

# --- HTTP cache ---
HTTP_CACHE_PATH=data/cache/http
HTTP_CACHE_ENABLED=true
